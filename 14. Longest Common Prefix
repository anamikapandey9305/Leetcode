// Lomngest common prefix problem -- Given an array of strings, find the longest prefix (starting part of a word) that is common to all strings.

If no common prefix exists, return an empty string.

class Solution {
    public String longestCommonPrefix(String[] s) {
        String p = s[0]; // taking first string as the initial prefix
        for (int i = 1; i < s.length; i++) // loop through remainig stringss
            while (!s[i].startsWith(p)) // check the current string
                p = p.substring(0, p.length() - 1);
        return p;
    }
}
